<?xml version="1.0" encoding="utf-8"?>
<!-- Android清单文件，配置应用组件（Activity/FileProvider）、权限声明及Intent过滤器 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        CAMERA: TakePicture() 使用系统相机 Intent，不需要声明此权限。
        如果需要直接使用 Camera API 可在运行时动态请求。
    -->
    <!-- <uses-permission android:name="android.permission.CAMERA" /> -->

    <!--
        READ_EXTERNAL_STORAGE: 此 App 使用 MediaStore/GetContent API，
        不需要直接读取外部存储，Android 10+ 无需此权限。
    -->
    <!-- <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" /> -->

    <!--
        WRITE_EXTERNAL_STORAGE: 仅在 Android 9 (API 28) 及以下需要保存图片到相册，
        Android 10+ 使用 MediaStore 不需要此权限。
    -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Android 13+ (API 33) 需要此权限才能通过 MediaStore 保存图片到相册 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.DigitalCard"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="31">

        <!-- FileProvider组件，用于在应用间安全共享文件（头像、拍照图片等） -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- 主Activity，应用入口，主题采用Material Light无ActionBar风格 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DigitalCard">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>